<script>
  // Test definitions: which tests are bilateral vs single
  const TESTS = [
    { id: 'squat',    sides: ['squat'] },
    { id: 'hurdle',   sides: ['hurdle-L', 'hurdle-R'] },
    { id: 'lunge',    sides: ['lunge-L', 'lunge-R'] },
    { id: 'shoulder', sides: ['shoulder-L', 'shoulder-R'] },
    { id: 'aslr',     sides: ['aslr-L', 'aslr-R'] },
    { id: 'pushup',   sides: ['pushup'] },
    { id: 'rotary',   sides: ['rotary-L', 'rotary-R'] }
  ];

  // Clearing test → which test gets zeroed
  const CLEARS = {
    clearShoulder:  'shoulder',
    clearExtension: 'pushup',
    clearFlexion:   'rotary'
  };

  function getRadio(name) {
    const el = document.querySelector(`input[name="${name}"]:checked`);
    return el ? parseInt(el.closest('label').dataset.val, 10) : null;
  }

  function setScoreDisplay(testId, finalScore, isAsymmetric) {
    const article = document.querySelector(`article[data-test="${testId}"]`);
    const display = article.querySelector('.score-display');
    const finalEl = display.querySelector('.final');
    display.classList.remove('flag-zero','flag-one','flag-three');
    if (finalScore === null) {
      finalEl.textContent = '—';
    } else {
      finalEl.textContent = finalScore;
      if (finalScore === 0) display.classList.add('flag-zero');
      else if (finalScore === 1) display.classList.add('flag-one');
      else if (finalScore === 3) display.classList.add('flag-three');
    }
  }

  function recompute() {
    let total = 0;
    let scoredCount = 0;
    let asymCount = 0;
    let painCount = 0;
    let lowCount = 0;

    // Apply clearing tests first by overriding radios visually? 
    // Strategy: just override the FINAL displayed/totaled score if the clearing box is checked.
    const clearStates = {};
    Object.keys(CLEARS).forEach(k => {
      clearStates[CLEARS[k]] = document.getElementById(k).checked;
    });

    TESTS.forEach(t => {
      const sideScores = t.sides.map(getRadio);
      const allFilled = sideScores.every(s => s !== null);
      const isAsym = t.sides.length > 1;

      let finalScore = null;
      if (allFilled) {
        finalScore = Math.min(...sideScores);
      }

      // Override with clearing test
      if (clearStates[t.id]) {
        finalScore = 0;
      }

      // Asymmetry flag (only if both sides filled & differ)
      const asymFlagEl = document.querySelector(`.asym-flag[data-flag="${t.id}"]`);
      if (asymFlagEl) {
        if (isAsym && allFilled && sideScores[0] !== sideScores[1]) {
          asymFlagEl.classList.add('show');
          asymCount++;
        } else {
          asymFlagEl.classList.remove('show');
        }
      }

      setScoreDisplay(t.id, finalScore, isAsym);

      if (finalScore !== null) {
        scoredCount++;
        total += finalScore;
        if (finalScore === 0) painCount++;
        if (finalScore < 2) lowCount++;
      }
    });

    document.getElementById('totalNum').textContent = scoredCount === 7 ? total : (scoredCount === 0 ? '—' : total + '*');
    document.getElementById('stampTotal').textContent = scoredCount === 7 ? `${total}/21` : (scoredCount === 0 ? '—' : `${total}/21*`);
    document.getElementById('testsScored').textContent = `${scoredCount}/7`;
    document.getElementById('asymCount').textContent = asymCount;
    document.getElementById('painCount').textContent = painCount;
    document.getElementById('lowCount').textContent = lowCount;

    // Highlight summary rows when nonzero
    const summary = document.getElementById('summaryBox');
    summary.querySelectorAll('.row').forEach((row, i) => {
      const vals = [scoredCount, asymCount, painCount, lowCount];
      if (i > 0 && vals[i] > 0) row.classList.add('flag');
      else row.classList.remove('flag');
    });
  }

  // Wire up listeners
  document.querySelectorAll('input[type="radio"], input[type="checkbox"]').forEach(el => {
    el.addEventListener('change', recompute);
  });

  // ──────── Corrective Exercise Database ────────
  // Each test has tier-1 (deeper deficit) and tier-2 (refinement) options.
  // Order within each list follows: mobility → motor control → stability/pattern.
  const CORRECTIVES = {
    aslr: {
      label: 'Active Straight-Leg Raise',
      why: 'Posterior-chain mobility on the moving leg + anterior core stability on the down leg.',
      hierarchy: 1,
      asymNote: 'Bias the harder side: 2 sets on the lower-scoring leg, 1 set on the other.',
      1: [
        { name: 'Supine hamstring stretch with strap', cue: 'Knee straight, opposite leg pinned to floor', sets: 3, reps: '30 s / side' },
        { name: 'Banded leg lowering', cue: 'Strap around foot, slow eccentric, low back flat', sets: 2, reps: '8 / side' },
        { name: 'Dead bug', cue: 'Ribs down, opposite arm/leg, exhale on extension', sets: 2, reps: '8 / side' },
        { name: '90/90 hip switches', cue: 'Tall posture, drive through heels', sets: 2, reps: '6 / side' }
      ],
      2: [
        { name: 'Active hamstring stretch (toe pull)', cue: 'Move into end range under control', sets: 2, reps: '10 / side' },
        { name: 'Leg lowering progression', cue: 'Both legs vertical, lower one at a time', sets: 2, reps: '8 / side' },
        { name: 'Dead bug with band pull-over', cue: 'Resist arch with band tension overhead', sets: 2, reps: '10 / side' }
      ]
    },
    shoulder: {
      label: 'Shoulder Mobility',
      why: 'Thoracic spine extension/rotation and shoulder capsule mobility.',
      hierarchy: 2,
      asymNote: 'Spend more time on the tighter side — usually the hand reaching down behind the back.',
      1: [
        { name: 'Foam-roller T-spine extensions', cue: 'Roller at mid-back, ribs down, support head', sets: 2, reps: '10' },
        { name: 'Brettzel stretch', cue: 'Side-lying, hold opposite knee + foot, breathe into ribs', sets: 2, reps: '30 s / side' },
        { name: 'Sleeper stretch', cue: 'Side-lying, gentle internal rotation, no force', sets: 2, reps: '30 s / side' },
        { name: 'Wall slides', cue: 'Low back + forearms on wall, slide overhead without arching', sets: 2, reps: '10' }
      ],
      2: [
        { name: 'Quadruped T-spine rotation', cue: 'Hand behind head, rotate elbow up', sets: 2, reps: '8 / side' },
        { name: 'Bench thoracic mobilization', cue: 'Forearms on bench, sink chest down', sets: 2, reps: '8 breaths' },
        { name: 'Wall angels', cue: 'Maintain contact, slow tempo', sets: 2, reps: '10' }
      ]
    },
    rotary: {
      label: 'Rotary Stability',
      why: 'Anti-rotation core control through quadruped and half-kneeling positions.',
      hierarchy: 3,
      asymNote: 'Train the harder diagonal first; double the volume on that side.',
      1: [
        { name: 'Quadruped opposite reach', cue: 'No rotation, slide hand forward / leg back low', sets: 2, reps: '6 / side' },
        { name: 'Bird dog with 3-second hold', cue: 'Spine neutral, exhale at end range', sets: 2, reps: '6 / side' },
        { name: 'Dead bug', cue: 'Ribs down, full exhale on extension', sets: 2, reps: '8 / side' }
      ],
      2: [
        { name: 'Bird dog with elbow-knee touch', cue: 'Round under control, then re-extend', sets: 2, reps: '8 / side' },
        { name: 'Bear crawl (forward/back)', cue: 'Hips low, opposite limbs, slow', sets: 2, reps: '10 m' },
        { name: 'Half-kneeling chop or lift', cue: 'Tall posture, resist rotation through cable/band', sets: 2, reps: '6 / side' }
      ]
    },
    pushup: {
      label: 'Trunk Stability Push-Up',
      why: 'Anterior core + scapular control to transfer force without lumbar lag.',
      hierarchy: 4,
      asymNote: '',
      1: [
        { name: 'RKC plank', cue: '20 s of maximum total-body tension', sets: 3, reps: '20 s' },
        { name: 'Modified push-up (knees) with strict spine', cue: 'Body lifts as one piece', sets: 2, reps: '6' },
        { name: 'Dead bug', cue: 'Build anterior core endurance', sets: 2, reps: '8 / side' },
        { name: 'Incline push-up (bench/box)', cue: 'Lower the height as control improves', sets: 2, reps: '6' }
      ],
      2: [
        { name: 'Plank with shoulder taps', cue: 'No hip rotation', sets: 2, reps: '10 / side' },
        { name: 'Tempo push-up (3 s down, pause)', cue: 'Ribs locked, no sag', sets: 2, reps: '6' },
        { name: 'Suspended (TRX) push-up', cue: 'Adjust angle to challenge', sets: 2, reps: '6' }
      ]
    },
    hurdle: {
      label: 'Hurdle Step',
      why: 'Single-leg stance stability + hip flexion mobility on the moving leg.',
      hierarchy: 5,
      asymNote: 'Train balance and hip flexion on the lower-scoring side first.',
      1: [
        { name: 'Half-kneeling hip flexor stretch', cue: 'Tuck pelvis, squeeze rear glute', sets: 2, reps: '30 s / side' },
        { name: 'Single-leg balance (eyes closed)', cue: 'Soft knee, build to 30 s', sets: 2, reps: '30 s / side' },
        { name: 'High-knee march in place', cue: 'Tall posture, hip above 90°', sets: 2, reps: '10 / side' },
        { name: 'Wall-supported hip airplane', cue: 'Slow, controlled internal/external rotation', sets: 2, reps: '6 / side' }
      ],
      2: [
        { name: 'Step-up to balance', cue: '6-inch box, pause at top, no toe push-off', sets: 2, reps: '8 / side' },
        { name: 'Single-leg deadlift patterning', cue: 'Hinge to horizontal, hands light on dowel', sets: 2, reps: '6 / side' },
        { name: 'Hip airplane (free)', cue: 'Hinge forward, rotate from the stance hip', sets: 2, reps: '6 / side' }
      ]
    },
    lunge: {
      label: 'Inline Lunge',
      why: 'Stability in a narrow base + hip mobility (flexion front leg, extension back leg).',
      hierarchy: 6,
      asymNote: 'The lower-scoring side is your front-leg deficit — train that stance pattern more.',
      1: [
        { name: 'Half-kneeling hip flexor stretch', cue: 'Pelvis tucked, slow breaths', sets: 2, reps: '30 s / side' },
        { name: 'Split-stance dowel reach', cue: 'Narrow stance, reach overhead without arching', sets: 2, reps: '10 / side' },
        { name: 'Reverse lunge to box', cue: 'Touch knee softly, drive through front heel', sets: 2, reps: '6 / side' }
      ],
      2: [
        { name: 'RNT lunge (band at front knee, pulling in)', cue: 'Resist the pull, push knee out', sets: 2, reps: '6 / side' },
        { name: 'Goblet reverse lunge', cue: 'Vertical torso, smooth tempo', sets: 2, reps: '6 / side' },
        { name: 'Half-kneeling rotation', cue: 'Stable pelvis, rotate from t-spine only', sets: 2, reps: '8 / side' }
      ]
    },
    squat: {
      label: 'Deep Squat',
      why: 'Compound pattern. Often improves once mobility/stability deficits above are cleared.',
      hierarchy: 7,
      asymNote: '',
      1: [
        { name: 'Knee-to-wall ankle mobility', cue: 'Big toe stays down, knee tracks over toes', sets: 2, reps: '10 / side' },
        { name: '90/90 hip stretch', cue: 'Tall posture, hinge over front shin', sets: 2, reps: '30 s / side' },
        { name: 'Goblet squat to box (heel-elevated if needed)', cue: 'Sit straight down, knees track toes', sets: 2, reps: '6' },
        { name: 'Cat-cow', cue: 'Move through full spinal range', sets: 2, reps: '8' }
      ],
      2: [
        { name: 'Goblet squat with 3-s pause at bottom', cue: 'Pry knees out, ribs over hips', sets: 2, reps: '6' },
        { name: 'Squat to stand (with reach)', cue: 'Walk hands to feet, drop into deep squat, reach overhead', sets: 2, reps: '6' },
        { name: 'Banded ankle dorsiflexion', cue: 'Band at ankle pulling back, knee over toes', sets: 2, reps: '10 / side' }
      ]
    }
  };

  // ════════ Exercise Customization System ════════
  // Customizations stored as exerciseCustomizations[`${testId}::${name}`] = {
  //   sets, reps, videos[], customName, deleted
  // }
  let exerciseCustomizations = {};

  const ckey = (testId, name) => `${testId}::${name}`;
  const escAttr = s => String(s ?? '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const escHTML = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  function exId(name) {
    return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  // Look up an exercise definition by testId + name
  function findExercise(testId, exName) {
    const data = CORRECTIVES[testId];
    if (!data) return null;
    for (const score of [1, 2]) {
      const found = (data[score] || []).find(e => e.name === exName);
      if (found) return found;
    }
    return null;
  }

  // Get effective values (custom overlaid on default)
  function getCustom(testId, ex) {
    const c = exerciseCustomizations[ckey(testId, ex.name)] || {};
    return {
      sets: c.sets !== undefined ? c.sets : ex.sets,
      reps: c.reps !== undefined ? c.reps : ex.reps,
      videos: Array.isArray(c.videos) ? [...c.videos] : [],
      customName: c.customName || '',
      deleted: !!c.deleted
    };
  }

  // Ensure the customization record exists, return mutable reference
  function ensureCustom(testId, exName) {
    const k = ckey(testId, exName);
    if (!exerciseCustomizations[k]) exerciseCustomizations[k] = {};
    return exerciseCustomizations[k];
  }

  const PLAY_ICON = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';

  // Recommendation hierarchy: lower hierarchy = address first
  const PROGRAM_ORDER = ['aslr', 'shoulder', 'rotary', 'pushup', 'hurdle', 'lunge', 'squat'];

  // Snapshot of last-generated program state (for partial re-renders)
  let _programState = { order: [], results: {} };

  // ════════ Render helpers ════════

  function renderVideoRow(testId, exName, index, value, allowRemove) {
    const empty = !value || !String(value).trim();
    return `<div class="video-row">
      <div class="ex-field video">
        <span class="lab">V${index+1}</span>
        <input type="url" placeholder="Paste link (YouTube, Vimeo, …)" value="${escAttr(value)}"
          data-test-id="${testId}" data-ex-name="${escAttr(exName)}"
          data-key="video" data-video-index="${index}">
      </div>
      <a class="ex-video-link ${empty ? 'empty' : ''}"
         href="${empty ? '#' : escAttr(value)}" target="_blank" rel="noopener"
         title="${empty ? 'Add a video link to enable' : 'Watch video'}">
        ${PLAY_ICON}
      </a>
      ${allowRemove ? `<button type="button" class="ico-btn video-remove"
         data-test-id="${testId}" data-ex-name="${escAttr(exName)}"
         data-video-index="${index}" title="Remove this video slot">×</button>` : ''}
    </div>`;
  }

  function renderVideoSection(testId, ex) {
    const c = getCustom(testId, ex);
    const videos = c.videos.length > 0 ? c.videos : [''];
    const allowMore = videos.length < 3;
    const allowRemove = videos.length > 1;
    return `<div class="video-section" data-vs="${testId}-${exId(ex.name)}">
      ${videos.map((v, i) => renderVideoRow(testId, ex.name, i, v, allowRemove)).join('')}
      ${allowMore ? `<button type="button" class="video-add"
        data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}">+ Add video link</button>` : ''}
    </div>`;
  }

  function renderExercise(testId, ex) {
    const c = getCustom(testId, ex);
    if (c.deleted) return '';
    const displayName = c.customName || ex.name;
    return `<li data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}">
      <div class="ex-content">
        <div class="ex-head-row">
          <input type="text" class="ex-name-input" value="${escAttr(displayName)}"
            data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}" data-key="customName"
            aria-label="Exercise name (editable)" title="Click to edit name">
          <button type="button" class="ico-btn ex-delete"
            data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}"
            title="Remove this exercise from the program">×</button>
        </div>
        <div class="ex-cue">${escHTML(ex.cue)}</div>
        <div class="ex-controls-row">
          <div class="ex-field sets">
            <span class="lab">Sets</span>
            <input type="number" min="1" max="20" value="${c.sets}"
              data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}" data-key="sets" inputmode="numeric">
          </div>
          <div class="ex-field reps">
            <span class="lab">Reps</span>
            <input type="text" value="${escAttr(c.reps)}"
              data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}" data-key="reps">
          </div>
        </div>
        ${renderVideoSection(testId, ex)}
      </div>
    </li>`;
  }

  function renderRemoved(testId, ex) {
    return `<div class="removed-row" data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}">
      <span>Removed: <strong>${escHTML(ex.name)}</strong></span>
      <button type="button" class="ex-restore"
        data-test-id="${testId}" data-ex-name="${escAttr(ex.name)}">Undo</button>
    </div>`;
  }

  function renderBlock(testId, score, asym, idx) {
    const data = CORRECTIVES[testId];
    const exercises = data[score] || [];
    const visible = exercises.filter(ex => !getCustom(testId, ex).deleted);
    const removed = exercises.filter(ex => getCustom(testId, ex).deleted);

    return `<div class="program-block" id="block-${testId}">
      <div class="pb-head">
        <div class="pb-num">${String(idx+1).padStart(2,'0')}</div>
        <div class="pb-title">
          <h3>${data.label}</h3>
          <div class="why">${escHTML(data.why)}</div>
        </div>
        <div class="pb-score">
          <span class="num s${score}">${score}</span>
          ${score === 1 ? 'dysfunctional' : 'compensated'}
        </div>
      </div>
      ${asym && data.asymNote ? `<div class="pb-asym">⚠ Asymmetry — ${escHTML(data.asymNote)}</div>` : ''}
      ${visible.length ? `<ol class="pb-exercises">
        ${visible.map(ex => renderExercise(testId, ex)).join('')}
      </ol>` : '<div class="program-empty" style="padding: 16px;">All exercises removed for this block. Restore one below or add custom work outside this tool.</div>'}
      ${removed.length ? `<div class="removed-list">
        <div class="removed-header">Removed (${removed.length})</div>
        ${removed.map(ex => renderRemoved(testId, ex)).join('')}
      </div>` : ''}
    </div>`;
  }

  // Surgical re-render of a single block (preserves state of other blocks)
  function regenerateBlock(testId) {
    const idx = _programState.order.indexOf(testId);
    const r = _programState.results[testId];
    if (idx < 0 || !r) return;
    const blockEl = document.getElementById(`block-${testId}`);
    if (!blockEl) return;
    const tmp = document.createElement('div');
    tmp.innerHTML = renderBlock(testId, r.final, r.asym, idx);
    blockEl.replaceWith(tmp.firstElementChild);
  }

  // Surgical re-render of just the video section for one exercise
  function regenerateVideoSection(testId, exName) {
    const ex = findExercise(testId, exName);
    if (!ex) return;
    const sectionEl = document.querySelector(`[data-vs="${testId}-${exId(exName)}"]`);
    if (!sectionEl) return;
    const tmp = document.createElement('div');
    tmp.innerHTML = renderVideoSection(testId, ex);
    sectionEl.replaceWith(tmp.firstElementChild);
  }

  // ════════ Main program generation ════════

  function generateProgram() {
    const programEl = document.getElementById('program');
    const body = document.getElementById('programBody');

    const results = {};
    let total = 0, scored = 0;
    const clearStates = {};
    Object.keys(CLEARS).forEach(k => {
      clearStates[CLEARS[k]] = document.getElementById(k).checked;
    });

    TESTS.forEach(t => {
      const sideScores = t.sides.map(getRadio);
      const allFilled = sideScores.every(s => s !== null);
      let finalScore = allFilled ? Math.min(...sideScores) : null;
      if (clearStates[t.id]) finalScore = 0;
      const isAsym = t.sides.length > 1 && allFilled && sideScores[0] !== sideScores[1];
      results[t.id] = { final: finalScore, sides: sideScores, asym: isAsym };
      if (finalScore !== null) { total += finalScore; scored++; }
    });

    if (scored === 0) {
      body.innerHTML = '<div class="program-empty">Score at least one test, then generate again.</div>';
      programEl.hidden = false;
      programEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }

    const today = new Date().toLocaleDateString('en-CA', { year:'numeric', month:'long', day:'numeric' });
    document.getElementById('progDate').textContent = today;
    document.getElementById('progScoreLine').textContent = `Composite ${total} / 21 · ${scored}/7 tests scored`;

    let html = '';

    const painTests = Object.entries(results)
      .filter(([_, r]) => r.final === 0)
      .map(([id]) => CORRECTIVES[id].label);
    if (painTests.length) {
      html += `<div class="program-banner">
        <strong>Medical Clearance Required</strong>
        Pain reported on: ${painTests.join(', ')}. Refer to a qualified healthcare provider before loading these patterns. Corrective work below is held until cleared.
      </div>`;
    }

    const needsWork = PROGRAM_ORDER
      .filter(id => results[id].final !== null && results[id].final > 0 && results[id].final < 3);

    if (needsWork.length) {
      html += `<div class="program-priority">
        <h3>Priority Order — Work in This Sequence</h3>
        <ol>${needsWork.map(id => {
          const score = results[id].final;
          const asym = results[id].asym ? '<span class="badge bad">asym</span>' : '';
          const sBadge = score === 1 ? '<span class="badge warn">score 1</span>' : '<span class="badge">score 2</span>';
          return `<li><strong>${CORRECTIVES[id].label}</strong> ${sBadge}${asym}</li>`;
        }).join('')}</ol>
      </div>`;
    }

    if (!needsWork.length && !painTests.length) {
      html += `<div class="program-clean">
        <div class="big">All Patterns Clean</div>
        <div class="small">Every scored test came in at 3. Continue with normal training; rescreen periodically.</div>
      </div>`;
    }

    needsWork.forEach((id, idx) => {
      html += renderBlock(id, results[id].final, results[id].asym, idx);
    });

    html += `<div class="program-priority" style="margin-top: 28px; margin-bottom: 0;">
      <h3>How To Use This Program</h3>
      <ol>
        <li>Run this routine <strong>3–5 days per week</strong>, either as a standalone session or before regular training.</li>
        <li>Address one block at a time — don't skip ahead. Mobility work first prepares the joint for stability work.</li>
        <li>Rescreen <strong>every 4 weeks</strong> to track progress and update the prescription.</li>
        <li>Quality over quantity — if form breaks down, stop the set.</li>
      </ol>
    </div>`;

    body.innerHTML = html;
    programEl.hidden = false;

    // Snapshot for surgical re-renders
    _programState = { order: needsWork, results };

    programEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  document.getElementById('programBtn').addEventListener('click', generateProgram);

  // ════════ Event delegation for program interactions ════════

  const programBody = document.getElementById('programBody');

  programBody.addEventListener('click', (e) => {
    const target = e.target;

    const deleteBtn = target.closest('.ex-delete');
    if (deleteBtn) {
      const { testId, exName } = deleteBtn.dataset;
      ensureCustom(testId, exName).deleted = true;
      regenerateBlock(testId);
      return;
    }

    const restoreBtn = target.closest('.ex-restore');
    if (restoreBtn) {
      const { testId, exName } = restoreBtn.dataset;
      ensureCustom(testId, exName).deleted = false;
      regenerateBlock(testId);
      return;
    }

    const addVideoBtn = target.closest('.video-add');
    if (addVideoBtn) {
      const { testId, exName } = addVideoBtn.dataset;
      const c = ensureCustom(testId, exName);
      if (!Array.isArray(c.videos)) c.videos = [];
      // If empty, the rendered "1 slot" was virtual — push two now to give 2 slots
      if (c.videos.length === 0) c.videos = ['', ''];
      else c.videos.push('');
      regenerateVideoSection(testId, exName);
      // Focus the newly-added (last empty) input
      const sectionEl = document.querySelector(`[data-vs="${testId}-${exId(exName)}"]`);
      if (sectionEl) {
        const inputs = sectionEl.querySelectorAll('input[data-key="video"]');
        if (inputs.length) inputs[inputs.length - 1].focus();
      }
      return;
    }

    const removeVideoBtn = target.closest('.video-remove');
    if (removeVideoBtn) {
      const { testId, exName, videoIndex } = removeVideoBtn.dataset;
      const c = ensureCustom(testId, exName);
      if (Array.isArray(c.videos)) {
        c.videos.splice(parseInt(videoIndex, 10), 1);
        regenerateVideoSection(testId, exName);
      }
      return;
    }
  });

  programBody.addEventListener('input', (e) => {
    const input = e.target;
    if (!input.matches('input[data-key]')) return;
    const { testId, exName, key, videoIndex } = input.dataset;
    if (!testId || !exName) return;
    const c = ensureCustom(testId, exName);
    let val = input.value;

    if (key === 'sets') {
      val = parseInt(val, 10);
      if (isNaN(val) || val < 1) val = 1;
      c.sets = val;
    } else if (key === 'reps') {
      c.reps = val;
    } else if (key === 'customName') {
      c.customName = val;
    } else if (key === 'video') {
      if (!Array.isArray(c.videos)) c.videos = [];
      const idx = parseInt(videoIndex, 10);
      while (c.videos.length <= idx) c.videos.push('');
      c.videos[idx] = val;
      // Update the play link visually without full re-render
      const link = input.closest('.video-row').querySelector('.ex-video-link');
      if (link) {
        const empty = !val.trim();
        link.classList.toggle('empty', empty);
        link.href = empty ? '#' : val;
        link.title = empty ? 'Add a video link to enable' : 'Watch video';
      }
    }
  });

  // ──────── Save / Load / Print / Reset ────────
  const STORAGE_KEY = 'coco_fms_2026_05_01';

  function gather() {
    const data = { radios: {}, checks: {}, notes: {}, screener: '', exercises: exerciseCustomizations };
    document.querySelectorAll('input[type="radio"]:checked').forEach(el => {
      data.radios[el.name] = el.closest('label').dataset.val;
    });
    document.querySelectorAll('input[type="checkbox"]').forEach(el => {
      data.checks[el.id] = el.checked;
    });
    document.querySelectorAll('textarea.notes-field').forEach(el => {
      data.notes[el.dataset.test] = el.value;
    });
    data.screener = document.getElementById('screener').value;
    return data;
  }

  function apply(data) {
    if (!data) return;
    // clear first
    document.querySelectorAll('input[type="radio"]').forEach(el => el.checked = false);
    Object.entries(data.radios || {}).forEach(([name, val]) => {
      const sel = document.querySelector(`input[name="${name}"]`);
      if (!sel) return;
      const labels = document.querySelectorAll(`input[name="${name}"]`);
      labels.forEach(l => {
        if (l.closest('label').dataset.val === val) l.checked = true;
      });
    });
    Object.entries(data.checks || {}).forEach(([id, v]) => {
      const el = document.getElementById(id);
      if (el) el.checked = v;
    });
    Object.entries(data.notes || {}).forEach(([k, v]) => {
      const el = document.querySelector(`textarea[data-test="${k}"]`);
      if (el) el.value = v;
    });
    document.getElementById('screener').value = data.screener || '';
    exerciseCustomizations = data.exercises || {};
    // Migrate any old-format records: keys without "::" or with single "video" string
    Object.keys(exerciseCustomizations).forEach(k => {
      const c = exerciseCustomizations[k];
      // Old: key was just exerciseName; convert by finding which test(s) contain it
      if (!k.includes('::')) {
        for (const testId in CORRECTIVES) {
          for (const score of [1, 2]) {
            const list = CORRECTIVES[testId][score] || [];
            if (list.some(ex => ex.name === k)) {
              const newKey = ckey(testId, k);
              if (!exerciseCustomizations[newKey]) {
                exerciseCustomizations[newKey] = { ...c };
              }
            }
          }
        }
        delete exerciseCustomizations[k];
        return;
      }
      // Old: { video: 'url' } → { videos: ['url'] }
      if (c.video !== undefined && !c.videos) {
        c.videos = c.video ? [c.video] : [];
        delete c.video;
      }
      if (!c.videos) c.videos = [];
    });
    recompute();
    // If the program section was open, regenerate it with the loaded customizations
    const programEl = document.getElementById('program');
    if (programEl && !programEl.hidden) {
      generateProgram();
    }
  }

  document.getElementById('saveBtn').addEventListener('click', () => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(gather()));
      flashBtn('saveBtn', 'Saved ✓');
    } catch (e) { alert('Save failed: ' + e.message); }
  });

  document.getElementById('loadBtn').addEventListener('click', () => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) { flashBtn('loadBtn', 'Nothing saved'); return; }
      apply(JSON.parse(raw));
      flashBtn('loadBtn', 'Loaded ✓');
    } catch (e) { alert('Load failed: ' + e.message); }
  });

  document.getElementById('printBtn').addEventListener('click', () => window.print());

  document.getElementById('resetBtn').addEventListener('click', () => {
    if (!confirm('Clear all entries on this form? (This does not delete a saved copy.)')) return;
    document.querySelectorAll('input[type="radio"]').forEach(el => el.checked = false);
    document.querySelectorAll('input[type="checkbox"]').forEach(el => el.checked = false);
    document.querySelectorAll('textarea.notes-field').forEach(el => el.value = '');
    document.getElementById('screener').value = '';
    exerciseCustomizations = {};
    document.getElementById('program').hidden = true;
    recompute();
  });

  function flashBtn(id, msg) {
    const btn = document.getElementById(id);
    const original = btn.textContent;
    btn.textContent = msg;
    setTimeout(() => btn.textContent = original, 1400);
  }

  // initial paint
  recompute();
</script>


</body></html>
