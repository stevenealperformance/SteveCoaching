<style>
  :root {
    --ink: #161412;
    --paper: #f4efe7;
    --paper-2: #ebe4d7;
    --rule: #1a1714;
    --accent: #c4361c;
    --accent-soft: #f3d9d2;
    --muted: #6b6258;
    --good: #2f6b3a;
    --warn: #b87b1f;
    --bad: #c4361c;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Archivo', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.5;
  }

  body {
    background-image:
      radial-gradient(circle at 20% 10%, rgba(196,54,28,0.04) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(22,20,18,0.04) 0%, transparent 40%);
    min-height: 100vh;
    padding: 32px 16px 80px;
  }

  .sheet {
    max-width: 1080px;
    margin: 0 auto;
    background: var(--paper);
    border: 1.5px solid var(--rule);
    box-shadow: 8px 8px 0 var(--rule);
    padding: 48px 56px;
    position: relative;
  }

  /* ───────────── HEADER ───────────── */

  .masthead {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: end;
    border-bottom: 3px double var(--rule);
    padding-bottom: 20px;
    margin-bottom: 28px;
  }

  .masthead .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .masthead h1 {
    font-family: 'Anton', 'Archivo', sans-serif;
    font-weight: 400;
    letter-spacing: 0.01em;
    font-size: clamp(48px, 7vw, 84px);
    line-height: 0.92;
    margin: 0;
    text-transform: uppercase;
  }

  .masthead h1 em {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
    text-transform: lowercase;
    letter-spacing: -0.02em;
  }

  .masthead .stamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    text-align: right;
    border-left: 1px solid var(--rule);
    padding-left: 16px;
  }

  .stamp .label {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ───────────── SUBJECT BAR ───────────── */

  .subject {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
    margin-bottom: 36px;
    background: var(--paper-2);
  }

  .subject .cell {
    padding: 14px 18px;
    border-right: 1px solid var(--rule);
  }

  .subject .cell:last-child { border-right: none; }

  .subject .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .subject .value {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
  }

  .subject input {
    background: transparent;
    border: none;
    border-bottom: 1px dashed var(--rule);
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    width: 100%;
    padding: 2px 0;
    outline: none;
  }

  .subject input:focus {
    border-bottom-color: var(--accent);
  }

  /* ───────────── INTRO + SCORING KEY ───────────── */

  .intro {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  .intro p {
    font-family: 'Fraunces', serif;
    font-size: 17px;
    line-height: 1.55;
    margin: 0;
  }

  .intro .lede::first-letter {
    font-family: 'Anton', sans-serif;
    font-size: 62px;
    float: left;
    line-height: 0.85;
    padding: 6px 10px 0 0;
    color: var(--accent);
  }

  .key {
    border: 1px solid var(--rule);
    padding: 16px 18px;
    background: var(--paper-2);
  }

  .key h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0 0 10px;
    color: var(--muted);
  }

  .key-row {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 12px;
    margin: 6px 0;
    align-items: baseline;
  }

  .key-row .num {
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    line-height: 1;
    color: var(--ink);
  }

  .key-row.k0 .num { color: var(--bad); }
  .key-row.k1 .num { color: var(--warn); }
  .key-row.k2 .num { color: var(--ink); }
  .key-row.k3 .num { color: var(--good); }

  .key-row .desc {
    font-size: 13px;
    line-height: 1.4;
  }

  /* ───────────── CLEARING TESTS ───────────── */

  .clearing {
    border: 1px solid var(--rule);
    padding: 18px 22px;
    margin-bottom: 36px;
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-2) 100%);
  }

  .clearing h2 {
    font-family: 'Anton', sans-serif;
    font-size: 20px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 4px;
  }

  .clearing .sub {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .clearing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .clear-card {
    border: 1px solid var(--rule);
    padding: 12px 14px;
    background: var(--paper);
    font-size: 13px;
  }

  .clear-card label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
  }

  .clear-card input[type="checkbox"] {
    margin-top: 3px;
    accent-color: var(--accent);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .clear-card .ct-name {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
    display: block;
    margin-bottom: 3px;
  }

  .clear-card .ct-affects {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ───────────── TEST CARDS ───────────── */

  .test {
    border: 1px solid var(--rule);
    margin-bottom: 24px;
    background: var(--paper);
    page-break-inside: avoid;
  }

  .test-header {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 0;
    border-bottom: 1px solid var(--rule);
    align-items: stretch;
  }

  .test-num {
    background: var(--ink);
    color: var(--paper);
    font-family: 'Anton', sans-serif;
    font-size: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .test-title {
    padding: 14px 20px;
  }

  .test-title h2 {
    font-family: 'Anton', sans-serif;
    font-size: 26px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1;
  }

  .test-title .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 4px;
  }

  .score-display {
    background: var(--paper-2);
    padding: 0 24px;
    display: flex;
    align-items: center;
    border-left: 1px solid var(--rule);
    min-width: 90px;
    justify-content: center;
  }

  .score-display .final {
    font-family: 'Anton', sans-serif;
    font-size: 56px;
    line-height: 1;
    color: var(--ink);
  }

  .score-display.flag-zero .final { color: var(--bad); }
  .score-display.flag-one .final { color: var(--warn); }
  .score-display.flag-three .final { color: var(--good); }

  .test-body {
    display: grid;
    grid-template-columns: 1fr 280px;
  }

  .criteria {
    padding: 20px 24px;
    border-right: 1px solid var(--rule);
  }

  .criteria h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 12px;
  }

  .crit-row {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 14px;
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px dotted rgba(22,20,18,0.2);
  }

  .crit-row:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .crit-num {
    font-family: 'Anton', sans-serif;
    font-size: 32px;
    line-height: 0.85;
    text-align: center;
  }

  .c0 .crit-num { color: var(--bad); }
  .c1 .crit-num { color: var(--warn); }
  .c2 .crit-num { color: var(--ink); }
  .c3 .crit-num { color: var(--good); }

  .crit-content ul {
    margin: 0;
    padding-left: 16px;
    font-size: 13px;
    line-height: 1.5;
  }

  .crit-content ul li {
    margin-bottom: 2px;
  }

  .crit-content .crit-head {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 11px;
    margin-bottom: 4px;
    display: block;
  }

  .crit-content em.measure {
    font-family: 'JetBrains Mono', monospace;
    font-style: normal;
    font-size: 12px;
    background: var(--accent-soft);
    padding: 1px 5px;
    border-radius: 2px;
  }

  /* score input panel */

  .input-panel {
    padding: 20px 24px;
    background: var(--paper-2);
  }

  .input-panel h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 12px;
  }

  .score-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    margin-bottom: 12px;
  }

  .score-buttons label {
    position: relative;
  }

  .score-buttons input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .score-buttons .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    border: 1.5px solid var(--rule);
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    background: var(--paper);
    transition: all 0.12s ease;
    user-select: none;
  }

  .score-buttons .btn:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .score-buttons input:checked + .btn {
    background: var(--ink);
    color: var(--paper);
  }

  .score-buttons label[data-val="0"] input:checked + .btn { background: var(--bad); border-color: var(--bad); color: #fff; }
  .score-buttons label[data-val="1"] input:checked + .btn { background: var(--warn); border-color: var(--warn); color: #fff; }
  .score-buttons label[data-val="3"] input:checked + .btn { background: var(--good); border-color: var(--good); color: #fff; }

  .side-block {
    margin-bottom: 12px;
  }

  .side-block .side-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .asym-flag {
    display: none;
    margin-top: 8px;
    padding: 6px 10px;
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .asym-flag.show { display: block; }

  .notes-field {
    width: 100%;
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 8px 10px;
    font-family: 'Fraunces', serif;
    font-size: 13px;
    resize: vertical;
    min-height: 50px;
    outline: none;
  }

  .notes-field:focus {
    border-color: var(--accent);
  }

  .notes-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 12px 0 4px;
  }

  /* ───────────── TOTAL ───────────── */

  .total {
    margin-top: 36px;
    border: 2px solid var(--rule);
    background: var(--ink);
    color: var(--paper);
    padding: 24px 32px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: center;
  }

  .total .label-block {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244,239,231,0.6);
    line-height: 1.4;
  }

  .total .label-block strong {
    color: var(--paper);
    font-weight: 400;
  }

  .total .big-score {
    font-family: 'Anton', sans-serif;
    font-size: 120px;
    line-height: 0.85;
    text-align: center;
  }

  .total .big-score .denom {
    color: rgba(244,239,231,0.4);
    font-size: 60px;
  }

  .total .summary {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .total .summary .row {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dotted rgba(244,239,231,0.2);
    padding: 2px 0;
  }

  .total .summary .row.flag {
    color: var(--accent);
  }

  /* ───────────── ACTION BAR ───────────── */

  .actions {
    position: sticky;
    bottom: 16px;
    margin-top: 24px;
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 12px 16px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    box-shadow: 4px 4px 0 var(--rule);
    z-index: 10;
  }

  .actions .hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-left: auto;
  }

  .actions button {
    background: var(--paper);
    border: 1.5px solid var(--rule);
    padding: 8px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .actions button:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .actions button.primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .actions button.primary:hover {
    background: var(--ink);
    border-color: var(--ink);
  }

  /* ───────────── FOOTER ───────────── */

  .colophon {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ───────────── PROGRAM ───────────── */

  .program {
    margin-top: 36px;
    border: 1.5px solid var(--rule);
    background: var(--paper);
  }

  .program[hidden] { display: none; }

  .program-head {
    background: var(--ink);
    color: var(--paper);
    padding: 24px 32px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: end;
    border-bottom: 3px double var(--paper);
  }

  .program-head .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244,239,231,0.6);
    margin-bottom: 6px;
  }

  .program-head h2 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 0.92;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  .program-head h2 em {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
    text-transform: lowercase;
    letter-spacing: -0.02em;
  }

  .program-head .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    text-align: right;
    color: rgba(244,239,231,0.7);
  }

  .program-body {
    padding: 28px 32px;
  }

  .program-banner {
    border: 1.5px solid var(--bad);
    background: var(--accent-soft);
    padding: 14px 18px;
    margin-bottom: 24px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .program-banner strong {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--bad);
    display: block;
    margin-bottom: 4px;
  }

  .program-priority {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    padding: 14px 18px;
    margin-bottom: 28px;
  }

  .program-priority h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 8px;
  }

  .program-priority ol {
    margin: 0;
    padding-left: 20px;
    font-family: 'Fraunces', serif;
    font-size: 14px;
    line-height: 1.7;
  }

  .program-priority ol li strong {
    font-weight: 600;
  }

  .program-priority ol li .badge {
    display: inline-block;
    margin-left: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 2px;
    background: var(--ink);
    color: var(--paper);
    letter-spacing: 0.06em;
    vertical-align: middle;
  }

  .program-priority ol li .badge.warn { background: var(--warn); }
  .program-priority ol li .badge.bad { background: var(--bad); }

  .program-block {
    border-top: 1px solid var(--rule);
    padding: 24px 0;
    page-break-inside: avoid;
  }

  .program-block:first-of-type { border-top: none; padding-top: 0; }

  .pb-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: center;
    margin-bottom: 14px;
  }

  .pb-num {
    font-family: 'Anton', sans-serif;
    font-size: 36px;
    line-height: 0.85;
    color: var(--accent);
  }

  .pb-title h3 {
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1;
  }

  .pb-title .why {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 13px;
    color: var(--muted);
    margin-top: 4px;
  }

  .pb-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: right;
    line-height: 1.4;
  }

  .pb-score .num {
    font-family: 'Anton', sans-serif;
    font-size: 28px;
    display: block;
    line-height: 1;
  }

  .pb-score .num.s0 { color: var(--bad); }
  .pb-score .num.s1 { color: var(--warn); }
  .pb-score .num.s2 { color: var(--ink); }

  .pb-asym {
    background: var(--accent-soft);
    border-left: 3px solid var(--accent);
    padding: 8px 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 14px;
  }

  .pb-exercises {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: ex;
  }

  .pb-exercises li {
    counter-increment: ex;
    padding: 16px 0;
    border-bottom: 1px dotted rgba(22,20,18,0.18);
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 14px;
    align-items: start;
  }

  .pb-exercises li:last-child { border-bottom: none; }

  .pb-exercises li::before {
    content: counter(ex, decimal-leading-zero);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.05em;
    padding-top: 8px;
  }

  .ex-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .ex-head-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    align-items: center;
  }

  /* Inline-editable name input — looks like text, hover hints editability */
  .ex-name-input {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px dashed transparent;
    padding: 2px 0;
    width: 100%;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .ex-name-input:hover {
    border-bottom-color: rgba(22,20,18,0.3);
  }

  .ex-name-input:focus {
    border-bottom-color: var(--accent);
    background: var(--paper-2);
    padding-left: 4px;
    padding-right: 4px;
  }

  /* Reusable small icon button */
  .ico-btn {
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(22,20,18,0.25);
    color: var(--muted);
    cursor: pointer;
    font-family: 'Anton', sans-serif;
    font-size: 18px;
    line-height: 1;
    padding: 0;
    transition: all 0.12s ease;
    flex-shrink: 0;
  }

  .ico-btn:hover {
    background: var(--bad);
    color: #fff;
    border-color: var(--bad);
  }

  .ex-cue {
    display: block;
    font-family: 'Archivo', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.45;
  }

  .ex-controls-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 2px;
  }

  .ex-field {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    overflow: hidden;
    min-width: 0;
  }

  .ex-field .lab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 8px;
    background: var(--paper);
    border-right: 1px solid var(--rule);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .ex-field input {
    border: none;
    background: transparent;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 6px 8px;
    outline: none;
    color: var(--ink);
    font-weight: 600;
    min-width: 0;
  }

  .ex-field input:focus { background: #fff; }
  .ex-field.sets input { width: 42px; text-align: center; }
  .ex-field.reps input { width: 130px; }
  .ex-field.video { flex: 1; min-width: 0; }
  .ex-field.video input { flex: 1; min-width: 0; width: 100%; }

  /* Video section — list of up to 3 video rows */
  .video-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }

  .video-row {
    display: flex;
    gap: 6px;
    align-items: stretch;
  }

  .ex-video-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: auto;
    min-height: 32px;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    border: 1px solid var(--rule);
    transition: all 0.15s ease;
    flex-shrink: 0;
  }

  .ex-video-link:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .ex-video-link.empty {
    background: transparent;
    color: var(--muted);
    border-style: dashed;
    pointer-events: none;
    opacity: 0.4;
  }

  .ex-video-link svg { width: 14px; height: 14px; }

  .video-add {
    align-self: flex-start;
    background: transparent;
    border: 1px dashed rgba(22,20,18,0.35);
    padding: 4px 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.12s ease;
  }

  .video-add:hover {
    border-color: var(--ink);
    color: var(--ink);
    background: var(--paper-2);
  }

  /* Removed exercises section at the bottom of each block */
  .removed-list {
    margin-top: 14px;
    padding: 10px 14px;
    background: rgba(22,20,18,0.04);
    border: 1px dashed rgba(22,20,18,0.2);
  }

  .removed-header {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .removed-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 4px 0;
    font-family: 'Fraunces', serif;
    font-size: 13px;
    font-style: italic;
    color: var(--muted);
  }

  .removed-row strong {
    font-weight: 600;
    text-decoration: line-through;
  }

  .ex-restore {
    background: transparent;
    border: 1px solid var(--rule);
    padding: 3px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.12s ease;
    font-style: normal;
  }

  .ex-restore:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .program-empty {
    padding: 32px;
    text-align: center;
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-style: italic;
    color: var(--muted);
  }

  .program-clean {
    background: linear-gradient(180deg, var(--paper) 0%, #e8efe5 100%);
    border: 1.5px solid var(--good);
    padding: 24px;
    text-align: center;
  }

  .program-clean .big {
    font-family: 'Anton', sans-serif;
    font-size: 36px;
    color: var(--good);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }

  .program-clean .small {
    font-family: 'Fraunces', serif;
    font-size: 15px;
    font-style: italic;
  }

  /* ───────────── RESPONSIVE ───────────── */

  @media (max-width: 860px) {
    .sheet { padding: 28px 22px; box-shadow: 4px 4px 0 var(--rule); }
    .masthead { grid-template-columns: 1fr; }
    .masthead .stamp { text-align: left; border-left: none; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 8px; }
    .subject { grid-template-columns: repeat(2, 1fr); }
    .subject .cell { border-bottom: 1px solid var(--rule); }
    .subject .cell:nth-child(2) { border-right: none; }
    .intro { grid-template-columns: 1fr; }
    .clearing-grid { grid-template-columns: 1fr; }
    .test-body { grid-template-columns: 1fr; }
    .criteria { border-right: none; border-bottom: 1px solid var(--rule); }
    .total { grid-template-columns: 1fr; text-align: center; gap: 16px; }
    .total .big-score { font-size: 88px; }
    .program-head { grid-template-columns: 1fr; }
    .program-head .meta { text-align: left; }
    .program-body { padding: 20px; }
    .pb-head { grid-template-columns: auto 1fr; }
    .pb-score { grid-column: 1 / -1; text-align: left; }
    .pb-exercises li { grid-template-columns: 24px 1fr; }
    .ex-controls-row { gap: 6px; }
    .ex-field.reps input { width: 100px; }
  }

  /* ───────────── PRINT ───────────── */

  @media print {
    body { background: white; padding: 0; }
    .sheet { box-shadow: none; border: none; padding: 16px; max-width: 100%; }
    .actions { display: none; }
    .test { break-inside: avoid; }
    .total { background: white; color: black; border: 2px solid black; }
    .total .label-block, .total .summary, .total .big-score .denom { color: #333; }

    /* Editable name input prints as plain text */
    .ex-name-input {
      border: none !important;
      background: transparent !important;
      padding: 0 !important;
    }
    /* Hide editing controls in print */
    .ex-delete,
    .ex-restore,
    .video-add,
    .video-remove,
    .removed-list { display: none !important; }
    /* Field labels print muted but visible */
    .ex-field { background: white; }
    .ex-field .lab { background: #f5f5f5; }
    /* Show video URLs as plain text under each exercise */
    .ex-field.video input { color: #555; }
    .ex-video-link { background: #333 !important; color: white !important; }
    .program-block { break-inside: avoid; page-break-inside: avoid; }
  }
</style>
</head>
<body>

<div class="sheet" id="sheet">

  <!-- Masthead -->
  <header class="masthead">
    <div>
      <div class="eyebrow">Functional Movement Screen · Score Sheet</div>
      <h1>The <em>Coco</em><br>Screen</h1>
    </div>
    <div class="stamp">
      <div><span class="label">Date</span><br>May 1, 2026</div>
      <div style="margin-top:8px"><span class="label">Total / 21</span><br><span id="stampTotal">10/21</span></div>
    </div>
  </header>

  <!-- Subject details -->
  <div class="subject">
    <div class="cell">
      <div class="label">Athlete</div>
      <div class="value">Coco</div>
    </div>
    <div class="cell">
      <div class="label">Hand Length</div>
      <div class="value">16.5 <span style="font-size:14px;color:var(--muted)">cm</span></div>
    </div>
    <div class="cell">
      <div class="label">Tibia Length</div>
      <div class="value">44.5 <span style="font-size:14px;color:var(--muted)">cm</span></div>
    </div>
    <div class="cell">
      <div class="label">Screened By</div>
      <input type="text" id="screener" placeholder="Initials">
    </div>
  </div>

  <!-- Intro + Key -->
  <section class="intro">
    <p class="lede">The Functional Movement Screen rates seven core movement patterns plus three pain-clearing tests. Each pattern is graded 0&nbsp;–&nbsp;3. Asymmetric tests (sides scored separately) take the <strong>lower</strong> of the two sides. Anything scoring a 1 — or any pain — flags a corrective priority before loading.</p>
    <div class="key">
      <h3>Scoring Key</h3>
      <div class="key-row k3"><span class="num">3</span><span class="desc">Performs perfectly without compensation.</span></div>
      <div class="key-row k2"><span class="num">2</span><span class="desc">Completes the pattern but with compensation.</span></div>
      <div class="key-row k1"><span class="num">1</span><span class="desc">Cannot perform the pattern as prescribed.</span></div>
      <div class="key-row k0"><span class="num">0</span><span class="desc">Pain at any point during the test or its clearing.</span></div>
    </div>
  </section>

  <!-- Clearing tests -->
  <section class="clearing">
    <h2>Pain Clearing Tests</h2>
    <div class="sub">Mark any test that produces pain — the linked movement is automatically scored 0.</div>
    <div class="clearing-grid">
      <div class="clear-card">
        <label>
          <input type="checkbox" id="clearShoulder" data-target="shoulder">
          <span>
            <span class="ct-name">Shoulder Impingement</span>
            Hand to opposite shoulder, lift elbow upward.
            <span class="ct-affects">Zeros · Test 4</span>
          </span>
        </label>
      </div>
      <div class="clear-card">
        <label>
          <input type="checkbox" id="clearExtension" data-target="pushup">
          <span>
            <span class="ct-name">Spinal Extension</span>
            Press-up from prone, hips on floor, arms extended.
            <span class="ct-affects">Zeros · Test 6</span>
          </span>
        </label>
      </div>
      <div class="clear-card">
        <label>
          <input type="checkbox" id="clearFlexion" data-target="rotary">
          <span>
            <span class="ct-name">Spinal Flexion</span>
            Posterior rocking from quadruped, chest to thighs.
            <span class="ct-affects">Zeros · Test 7</span>
          </span>
        </label>
      </div>
    </div>
  </section>

  <!-- ════════ TEST 1: DEEP SQUAT ════════ -->
  <article class="test" data-test="squat" data-symmetric="true">
    <div class="test-header">
      <div class="test-num">1</div>
      <div class="test-title">
        <h2>Deep Squat</h2>
        <div class="tag">Bilateral · Symmetrical, full-body mechanics</div>
      </div>
      <div class="score-display flag-one"><div class="final">1</div></div>
    </div>
    <div class="test-body">
      <div class="criteria">
        <h3>Scoring Criteria</h3>
        <div class="crit-row c3"><div class="crit-num">3</div><div class="crit-content">
          <span class="crit-head">Optimal — Heels Flat</span>
          <ul>
            <li>Upper torso parallel with tibia or toward vertical</li>
            <li>Femur below horizontal</li>
            <li>Knees aligned over feet</li>
            <li>Dowel aligned over feet</li>
          </ul>
        </div></div>
        <div class="crit-row c2"><div class="crit-num">2</div><div class="crit-content">
          <span class="crit-head">Compensated — Heels Elevated</span>
          <ul>
            <li>All criteria above met, but only with heels on a 2x6 board</li>
          </ul>
        </div></div>
        <div class="crit-row c1"><div class="crit-num">1</div><div class="crit-content">
          <span class="crit-head">Dysfunctional</span>
          <ul>
            <li>Tibia and torso not parallel</li>
            <li>Femur not below horizontal</li>
            <li>Knees not aligned over feet</li>
            <li>Lumbar flexion noted (even with heels elevated)</li>
          </ul>
        </div></div>
        <div class="crit-row c0"><div class="crit-num">0</div><div class="crit-content">
          <span class="crit-head">Pain</span>
          <ul><li>Pain anywhere during the movement</li></ul>
        </div></div>
      </div>
      <div class="input-panel">
        <h3>Score</h3>
        <div class="score-buttons" data-side="single">
          <label data-val="0"><input type="radio" name="squat"><span class="btn">0</span></label>
          <label data-val="1"><input type="radio" name="squat"><span class="btn">1</span></label>
          <label data-val="2"><input type="radio" name="squat"><span class="btn">2</span></label>
          <label data-val="3"><input type="radio" name="squat"><span class="btn">3</span></label>
        </div>
        <label class="notes-label">Notes</label>
        <textarea class="notes-field" data-test="squat"></textarea>
      </div>
    </div>
  </article>

  <!-- ════════ TEST 2: HURDLE STEP ════════ -->
  <article class="test" data-test="hurdle" data-symmetric="false">
    <div class="test-header">
      <div class="test-num">2</div>
      <div class="test-title">
        <h2>Hurdle Step</h2>
        <div class="tag">Asymmetrical · Hurdle set to <em>44.5&nbsp;cm</em> (tibia tuberosity)</div>
      </div>
      <div class="score-display"><div class="final">2</div></div>
    </div>
    <div class="test-body">
      <div class="criteria">
        <h3>Scoring Criteria</h3>
        <div class="crit-row c3"><div class="crit-num">3</div><div class="crit-content">
          <span class="crit-head">Optimal</span>
          <ul>
            <li>Hips, knees, and ankles remain aligned in the sagittal plane</li>
            <li>Minimal to no movement in the lumbar spine</li>
            <li>Dowel and hurdle remain parallel</li>
          </ul>
        </div></div>
        <div class="crit-row c2"><div class="crit-num">2</div><div class="crit-content">
          <span class="crit-head">Compensated</span>
          <ul>
            <li>Alignment lost between hips, knees, and ankles</li>
            <li>Movement noted in the lumbar spine</li>
            <li>Dowel and hurdle do not remain parallel</li>
          </ul>
        </div></div>
        <div class="crit-row c1"><div class="crit-num">1</div><div class="crit-content">
          <span class="crit-head">Dysfunctional</span>
          <ul>
            <li>Foot makes contact with the hurdle</li>
            <li>Loss of balance is noted</li>
          </ul>
        </div></div>
        <div class="crit-row c0"><div class="crit-num">0</div><div class="crit-content">
          <span class="crit-head">Pain</span>
          <ul><li>Pain anywhere during the movement</li></ul>
        </div></div>
      </div>
      <div class="input-panel">
        <h3>Score (lower side counts)</h3>
        <div class="side-block">
          <div class="side-label">Left</div>
          <div class="score-buttons" data-side="left">
            <label data-val="0"><input type="radio" name="hurdle-L"><span class="btn">0</span></label>
            <label data-val="1"><input type="radio" name="hurdle-L"><span class="btn">1</span></label>
            <label data-val="2"><input type="radio" name="hurdle-L"><span class="btn">2</span></label>
            <label data-val="3"><input type="radio" name="hurdle-L"><span class="btn">3</span></label>
          </div>
        </div>
        <div class="side-block">
          <div class="side-label">Right</div>
          <div class="score-buttons" data-side="right">
            <label data-val="0"><input type="radio" name="hurdle-R"><span class="btn">0</span></label>
            <label data-val="1"><input type="radio" name="hurdle-R"><span class="btn">1</span></label>
            <label data-val="2"><input type="radio" name="hurdle-R"><span class="btn">2</span></label>
            <label data-val="3"><input type="radio" name="hurdle-R"><span class="btn">3</span></label>
          </div>
        </div>
        <div class="asym-flag" data-flag="hurdle">⚠ Asymmetry detected</div>
        <label class="notes-label">Notes</label>
        <textarea class="notes-field" data-test="hurdle"></textarea>
      </div>
    </div>
  </article>

  <!-- ════════ TEST 3: INLINE LUNGE ════════ -->
  <article class="test" data-test="lunge" data-symmetric="false">
    <div class="test-header">
      <div class="test-num">3</div>
      <div class="test-title">
        <h2>Inline Lunge</h2>
        <div class="tag">Asymmetrical · Stride set to <em>44.5&nbsp;cm</em> (tibia length)</div>
      </div>
      <div class="score-display"><div class="final">2</div></div>
    </div>
    <div class="test-body">
      <div class="criteria">
        <h3>Scoring Criteria</h3>
        <div class="crit-row c3"><div class="crit-num">3</div><div class="crit-content">
          <span class="crit-head">Optimal</span>
          <ul>
            <li>Dowel contacts (head, thoracic spine, sacrum) maintained</li>
            <li>Dowel remains vertical</li>
            <li>No torso movement</li>
            <li>Dowel and feet remain in sagittal plane</li>
            <li>Knee touches board behind heel of front foot</li>
          </ul>
        </div></div>
        <div class="crit-row c2"><div class="crit-num">2</div><div class="crit-content">
          <span class="crit-head">Compensated</span>
          <ul>
            <li>One or more of the optimal criteria are lost</li>
            <li>Dowel may shift, torso may rotate, or knee fails to reach the board</li>
          </ul>
        </div></div>
        <div class="crit-row c1"><div class="crit-num">1</div><div class="crit-content">
          <span class="crit-head">Dysfunctional</span>
          <ul><li>Loss of balance during the movement</li></ul>
        </div></div>
        <div class="crit-row c0"><div class="crit-num">0</div><div class="crit-content">
          <span class="crit-head">Pain</span>
          <ul><li>Pain anywhere during the movement</li></ul>
        </div></div>
      </div>
      <div class="input-panel">
        <h3>Score (lower side counts)</h3>
        <div class="side-block">
          <div class="side-label">Left foot forward</div>
          <div class="score-buttons" data-side="left">
            <label data-val="0"><input type="radio" name="lunge-L"><span class="btn">0</span></label>
            <label data-val="1"><input type="radio" name="lunge-L"><span class="btn">1</span></label>
            <label data-val="2"><input type="radio" name="lunge-L"><span class="btn">2</span></label>
            <label data-val="3"><input type="radio" name="lunge-L"><span class="btn">3</span></label>
          </div>
        </div>
        <div class="side-block">
          <div class="side-label">Right foot forward</div>
          <div class="score-buttons" data-side="right">
            <label data-val="0"><input type="radio" name="lunge-R"><span class="btn">0</span></label>
            <label data-val="1"><input type="radio" name="lunge-R"><span class="btn">1</span></label>
            <label data-val="2"><input type="radio" name="lunge-R"><span class="btn">2</span></label>
            <label data-val="3"><input type="radio" name="lunge-R"><span class="btn">3</span></label>
          </div>
        </div>
        <div class="asym-flag" data-flag="lunge">⚠ Asymmetry detected</div>
        <label class="notes-label">Notes</label>
        <textarea class="notes-field" data-test="lunge"></textarea>
      </div>
    </div>
  </article>

  <!-- ════════ TEST 4: SHOULDER MOBILITY ════════ -->
  <article class="test" data-test="shoulder" data-symmetric="false">
    <div class="test-header">
      <div class="test-num">4</div>
      <div class="test-title">
        <h2>Shoulder Mobility</h2>
        <div class="tag">Asymmetrical · Hand length <em>16.5&nbsp;cm</em> drives thresholds</div>
      </div>
      <div class="score-display"><div class="final">2</div></div>
    </div>
    <div class="test-body">
      <div class="criteria">
        <h3>Scoring Criteria — Distance Between Fists</h3>
        <div class="crit-row c3"><div class="crit-num">3</div><div class="crit-content">
          <span class="crit-head">Optimal</span>
          <ul>
            <li>Fists within <em class="measure">≤ 16.5 cm</em> (one hand length)</li>
          </ul>
        </div></div>
        <div class="crit-row c2"><div class="crit-num">2</div><div class="crit-content">
          <span class="crit-head">Compensated</span>
          <ul>
            <li>Fists within <em class="measure">≤ 24.75 cm</em> (1.5 hand lengths)</li>
          </ul>
        </div></div>
        <div class="crit-row c1"><div class="crit-num">1</div><div class="crit-content">
          <span class="crit-head">Dysfunctional</span>
          <ul>
            <li>Fists more than <em class="measure">&gt; 24.75 cm</em> apart (greater than 1.5 hand lengths)</li>
          </ul>
        </div></div>
        <div class="crit-row c0"><div class="crit-num">0</div><div class="crit-content">
          <span class="crit-head">Pain</span>
          <ul><li>Positive shoulder impingement clearing test</li></ul>
        </div></div>
      </div>
      <div class="input-panel">
        <h3>Score (lower side counts)</h3>
        <div class="side-block">
          <div class="side-label">Left (R hand reaches up &amp; over)</div>
          <div class="score-buttons" data-side="left">
